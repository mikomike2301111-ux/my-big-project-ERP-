{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/rpc", "destination": "/api/rpc.js" },
    { "source": "/api/email-track(.*)", "destination": "/api/email-track.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/rpc.js": {
      "maxDuration": 10
    },
    "api/email-track.js": {
      "maxDuration": 10
    }
  }
}