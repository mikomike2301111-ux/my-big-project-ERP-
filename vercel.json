{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/rpc", "destination": "/api/rpc.js" },
    { "source": "/api/leave-action", "destination": "/api/leave-action.js" },
    { "source": "/api/approval-action", "destination": "/api/approval-action.js" },
    { "source": "/api/requisition-action", "destination": "/api/requisition-action.js" },
    { "source": "/api/email-track(.*)", "destination": "/api/email-track.js" },
    { "source": "/api/ai-assistant", "destination": "/api/ai-assistant.js" },
    { "source": "/api/ai-daily-briefing", "destination": "/api/ai-daily-briefing.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/ai-daily-briefing",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "api/rpc.js": {
      "maxDuration": 60
    },
    "api/leave-action.js": {
      "maxDuration": 30
    },
    "api/approval-action.js": {
      "maxDuration": 30
    },
    "api/requisition-action.js": {
      "maxDuration": 30
    },
    "api/email-track.js": {
      "maxDuration": 30
    },
    "api/ai-assistant.js": {
      "maxDuration": 60
    },
    "api/ai-daily-briefing.js": {
      "maxDuration": 30
    }
  }
}
